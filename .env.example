# ==========================================
# Frontend Variables (must start with VITE_)
# ==========================================

# The base URL of your deployed backend (e.g., your Render URL). 
# If testing locally, the app will automatically use '/api' to proxy the request.
VITE_API_URL=https://REPLACE_ME_WITH_RENDER_URL.onrender.com

# The public API used to fetch synchronized lyrics
VITE_LYRICS_API=https://lrclib.net/api/search


# ==========================================
# Backend Variables (for server/index.js)
# ==========================================

# The port the backend runs on (Render sets this automatically)
PORT=3001

# The host binding for the backend
HOST=0.0.0.0

# The API used for fallback lyrics scraping
GENIUS_API_URL=https://genius.com/api/search/multi
